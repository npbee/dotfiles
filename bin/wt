#!/usr/bin/env bash
#
# wt — Git worktree sessions for AeroSpace + Ghostty + tmux + Claude Code
#
#   Each session = one worktree + one tmux session (named after the branch)
#   + one AeroSpace workspace + a Ghostty window attached to the tmux session
#   running `claude`, tiled next to a browser pointed at that session's dev
#   server. tmux owns the process tree, so sessions survive Ghostty restarts
#   and you can detach/reattach or switch between them with prefix + s.
#
# Usage:
#   wt new    <branch> [workspace]   Create worktree + tmux session + window + browser
#   wt rm     <branch>               Tear down: kill session, remove the worktree
#   wt switch <branch>               Attach/switch to a session's tmux (no new window)
#   wt ls                            List active worktree sessions
#
set -euo pipefail

# --- Config (override via env) -----------------------------------------------
BROWSER_APP="${WT_BROWSER:-Google Chrome}"
PORT_BASE="${WT_PORT_BASE:-3000}"     # ports land in PORT_BASE .. PORT_BASE+999
AGENT_CMD="${WT_AGENT:-claude}"       # the agent to launch in the tmux session
# How to open a terminal window attached to a session. {sess} is substituted.
# Default opens a new Ghostty window running `tmux attach`.
TERM_CMD="${WT_TERM_CMD:-open -na Ghostty --args -e tmux attach -t {sess}}"

# --- Helpers -----------------------------------------------------------------
die()  { echo "wt: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

repo_root() { git rev-parse --show-toplevel 2>/dev/null || die "not inside a git repo"; }

# Deterministic dev-server port from the branch name (stable across restarts).
branch_port() {
  echo $(( PORT_BASE + $(printf '%s' "$1" | cksum | cut -d' ' -f1) % 1000 ))
}

# Default workspace = first alphanumeric char of the branch, uppercased.
default_ws() {
  local c; c="$(printf '%s' "$1" | tr -cd 'A-Za-z0-9' | head -c1 | tr 'a-z' 'A-Z')"
  echo "${c:-1}"
}

# tmux session name: tmux forbids '.' and ':' — and '/' is awkward — so map them.
sess_for() { printf '%s' "${1//[.:\/]/-}"; }

# Filesystem-safe dir name (branch may contain slashes, e.g. feature/x).
wt_dir_for() {
  local root branch
  root="$(repo_root)"; branch="$1"
  echo "$root/../.worktrees/$(basename "$root")/${branch//\//-}"
}

# Exact-match check (=name) so 'feat-1' doesn't match 'feat-12'.
session_alive() { tmux has-session -t "=$1" 2>/dev/null; }

# Open a terminal window attached to a session via TERM_CMD (best effort).
open_window() {
  local sess="$1" cmd="${TERM_CMD//\{sess\}/$1}"
  eval "$cmd" >/dev/null 2>&1 &
}

# --- Subcommands -------------------------------------------------------------
cmd_new() {
  local branch="${1:-}" ws port root wt_dir sess
  [ -n "$branch" ] || die "usage: wt new <branch> [workspace]"
  ws="${2:-$(default_ws "$branch")}"
  port="$(branch_port "$branch")"
  root="$(repo_root)"
  wt_dir="$(wt_dir_for "$branch")"
  sess="$(sess_for "$branch")"

  # 1. Worktree (create the branch if it doesn't exist yet)
  if ! git -C "$root" worktree list | grep -qF "$wt_dir"; then
    if git -C "$root" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$root" worktree add "$wt_dir" "$branch"
    else
      git -C "$root" worktree add -b "$branch" "$wt_dir"
    fi
  fi

  # 2. tmux session rooted at the worktree, running the agent (idempotent)
  if ! session_alive "$sess"; then
    tmux new-session -d -s "$sess" -c "$wt_dir"
    tmux send-keys -t "=$sess" "PORT=$port $AGENT_CMD" Enter
  fi

  # 3. Focus the target workspace so the new window lands there
  have aerospace && aerospace workspace "$ws" || true

  # 4. Window attached to the session (or switch in place if already in tmux)
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "=$sess"
  else
    open_window "$sess"
  fi

  # 5. Browser window pointed at this session's dev server
  open -na "$BROWSER_APP" --args --new-window "http://localhost:$port"

  echo "wt: session '$branch' → tmux:$sess, workspace $ws, port $port"
  echo "    worktree: $wt_dir"
}

cmd_switch() {
  local branch="${1:-}" sess
  [ -n "$branch" ] || die "usage: wt switch <branch>"
  sess="$(sess_for "$branch")"
  session_alive "$sess" || die "no tmux session for '$branch' (try: wt new $branch)"
  if [ -n "${TMUX:-}" ]; then tmux switch-client -t "=$sess"
  else                        tmux attach -t "=$sess"; fi
}

cmd_rm() {
  local branch="${1:-}" root wt_dir port sess
  [ -n "$branch" ] || die "usage: wt rm <branch>"
  root="$(repo_root)"
  wt_dir="$(wt_dir_for "$branch")"
  port="$(branch_port "$branch")"
  sess="$(sess_for "$branch")"

  # Kill the tmux session (best effort) — this also closes any attached window.
  session_alive "$sess" && tmux kill-session -t "=$sess" || true

  # Close the browser tab/window for this session's port (best effort)
  if [ "$BROWSER_APP" = "Google Chrome" ] && have osascript; then
    osascript - "$port" <<'OSA' 2>/dev/null || true
on run argv
  set thePort to item 1 of argv
  tell application "Google Chrome"
    repeat with w in windows
      repeat with t in (tabs of w)
        if (URL of t) contains ("localhost:" & thePort) then close t
      end repeat
    end repeat
  end tell
end run
OSA
  fi

  # Remove the worktree (use --force only if you've committed/stashed)
  if git -C "$root" worktree list | grep -qF "$wt_dir"; then
    git -C "$root" worktree remove "$wt_dir" \
      || die "worktree has changes — commit/stash, or: git worktree remove --force \"$wt_dir\""
  fi
  echo "wt: removed session '$branch'"
}

cmd_ls() {
  local root; root="$(repo_root)"
  echo "Active worktree sessions:"
  git -C "$root" worktree list | while read -r path _ rest; do
    case "$path" in
      *"/.worktrees/"*)
        local b sess state; b="$(basename "$path")"; sess="$(sess_for "$b")"
        if session_alive "$sess"; then state="tmux:live"; else state="tmux:dead"; fi
        printf "  %-24s ws=%-3s port=%-5s %-10s %s\n" \
          "$b" "$(default_ws "$b")" "$(branch_port "$b")" "$state" "$path"
        ;;
    esac
  done
}

# --- Dispatch ----------------------------------------------------------------
case "${1:-}" in
  new|up)        shift; cmd_new    "$@" ;;
  rm|down)       shift; cmd_rm     "$@" ;;
  switch|attach) shift; cmd_switch "$@" ;;
  ls|list)       shift; cmd_ls     "$@" ;;
  *) cat >&2 <<EOF
wt — Git worktree sessions for AeroSpace + Ghostty + tmux + Claude Code

  wt new    <branch> [workspace]   Create worktree + tmux session + window + browser
  wt rm     <branch>               Tear down windows/session and remove the worktree
  wt switch <branch>               Attach/switch to a session's tmux
  wt ls                            List active sessions
EOF
     exit 1 ;;
esac
