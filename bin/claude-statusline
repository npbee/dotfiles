#!/usr/bin/env bash
# Claude Code statusline:
#   <directory> | <git branch> | <token count> <token percentage>
#
# Wired up via ~/.claude/settings.json:
#   { "statusLine": { "type": "command", "command": "$HOME/.bin/claude-statusline" } }
#
# Reads the session payload Claude Code writes to stdin, then derives:
#   - directory: basename of the workspace dir
#   - git branch: from `git -C <dir>` so it works in worktrees
#   - tokens: input + cache_read + cache_creation (= effective context use),
#     read from the stdin payload's context_window.current_usage when present,
#     otherwise scanned out of the transcript JSONL for older Claude Code builds

set -u

input=$(cat)

jq_field() { printf '%s' "$input" | jq -r "$1" 2>/dev/null; }

cwd=$(jq_field '.workspace.current_dir // .cwd // ""')
transcript=$(jq_field '.transcript_path // ""')
model=$(jq_field '
    (.model // null) as $m
    | if ($m | type) == "object" then ($m.display_name // $m.id // "")
      elif ($m | type) == "string" then $m
      else "" end
')
window_size=$(jq_field '.context_window.context_window_size // ""')
cw_tokens=$(jq_field '
    (.context_window.current_usage // null) as $u
    | if ($u | type) == "object" then
        (($u.input_tokens // 0)
         + ($u.cache_read_input_tokens // 0)
         + ($u.cache_creation_input_tokens // 0))
      elif ($u | type) == "number" then $u
      else "" end
')
cw_percent=$(jq_field '.context_window.used_percentage // ""')
cost_usd=$(jq_field '.cost.total_cost_usd // ""')

# Window size: prefer payload, then env override, then 200k.
if [ -z "$window_size" ] || [ "$window_size" = "null" ]; then
    window_size=${CLAUDE_STATUSLINE_CONTEXT_MAX:-200000}
fi

dir=""
if [ -n "$cwd" ]; then
    if [ "$cwd" = "$HOME" ]; then
        dir="~"
    else
        dir=$(basename "$cwd")
    fi
fi

branch=""
if [ -n "$cwd" ] && [ -d "$cwd" ]; then
    branch=$(git -C "$cwd" symbolic-ref --quiet --short HEAD 2>/dev/null) \
        || branch=$(git -C "$cwd" rev-parse --short HEAD 2>/dev/null) \
        || branch=""
fi

tokens=0
if [ -n "$cw_tokens" ] && [ "$cw_tokens" != "null" ]; then
    tokens=$cw_tokens
elif [ -n "$transcript" ] && [ -f "$transcript" ]; then
    val=$(tail -r "$transcript" 2>/dev/null \
        | jq -r 'select(.type == "assistant" and (.message.usage // false))
                 | .message.usage
                 | (.input_tokens // 0)
                 + (.cache_read_input_tokens // 0)
                 + (.cache_creation_input_tokens // 0)' 2>/dev/null \
        | head -n1)
    if [ -n "$val" ]; then
        tokens=$val
    fi
fi

if [ -n "$cw_percent" ] && [ "$cw_percent" != "null" ]; then
    # Drop fractional part; statusline prints whole percentages.
    percent=${cw_percent%.*}
elif [ "$window_size" -gt 0 ]; then
    percent=$((tokens * 100 / window_size))
else
    percent=0
fi

fmt_tokens() {
    local n=$1
    if [ "$n" -lt 1000 ]; then
        printf '%d' "$n"
    elif [ "$n" -lt 10000 ]; then
        printf '%d.%dk' $((n / 1000)) $(((n / 100) % 10))
    elif [ "$n" -lt 1000000 ]; then
        printf '%dk' $((n / 1000))
    else
        printf '%dM' $((n / 1000000))
    fi
}

# Color the token count by usage. Disabled when NO_COLOR is set.
if [ -n "${NO_COLOR:-}" ]; then
    c_tok="" c_reset=""
else
    esc=$'\033'
    c_reset="${esc}[0m"
    if   [ "$percent" -ge 80 ]; then c_tok="${esc}[31m"  # red
    elif [ "$percent" -ge 50 ]; then c_tok="${esc}[33m"  # yellow
    else                             c_tok="${esc}[32m"  # green
    fi
fi

token_field=$(printf '%s/%s (%d%%)' "$(fmt_tokens "$tokens")" "$(fmt_tokens "$window_size")" "$percent")

cost_field=""
if [ -n "$cost_usd" ] && [ "$cost_usd" != "null" ]; then
    cost_field=$(awk -v c="$cost_usd" 'BEGIN {
        if (c < 1)        printf "$%.2f", c
        else if (c < 10)  printf "$%.2f", c
        else              printf "$%.1f", c
    }')
fi

parts=()
[ -n "$dir" ]    && parts+=("$dir")
[ -n "$branch" ] && parts+=("$branch")
[ -n "$model" ]  && parts+=("$model")
parts+=("${c_tok}${token_field}${c_reset}")
[ -n "$cost_field" ] && parts+=("$cost_field")

out=""
for p in "${parts[@]}"; do
    if [ -z "$out" ]; then
        out="$p"
    else
        out="${out} | ${p}"
    fi
done

printf '%s' "$out"
